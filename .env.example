# ── Stochastic Gap Audit v2.0 — Environment Variables ────────────────────────
# Copy this file to .env and fill in the values you need.
# All variables are optional — the tool runs in dry-run (mock) mode without any.

# ── OpenRouter API (optional) ─────────────────────────────────────────────────
# Your OpenRouter API key. Obtain one at https://openrouter.ai/
# When absent, the tool auto-switches to mock mode (zero network calls).
OPENROUTER_API_KEY=

# Base URL for the OpenRouter API (rarely needs changing)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Request timeout in seconds for each API call
OPENROUTER_TIMEOUT=30

# HTTP Referer header sent to OpenRouter (identifies your app)
OPENROUTER_REFERRER=https://github.com/dakshjain-1616/stochastic-gap-audit

# Max tokens per model response
OPENROUTER_MAX_TOKENS=512

# Sampling temperature (0.0 = deterministic, 1.0 = creative)
OPENROUTER_TEMPERATURE=0.7

# Max retry attempts on transient API failures (exponential backoff)
OPENROUTER_MAX_RETRIES=3

# Base delay (seconds) between retry attempts (doubles each attempt)
OPENROUTER_RETRY_DELAY=1.0

# ── Audit Settings ────────────────────────────────────────────────────────────
# Default model ID to audit (OpenRouter format).
# Latest recommended models (as of 2026-03):
#   Budget / free:
#     mistralai/mistral-small-2603  (262k ctx, 2026-03-16)
#     openai/gpt-5.4-nano           (400k ctx, 2026-03-17)
#     nvidia/nemotron-3-super-120b-a12b:free  (262k ctx, free tier)
#   Premium:
#     openai/gpt-5.4-mini           (400k ctx, 2026-03-17)
#     x-ai/grok-4.20-beta           (2000k ctx, 2026-03-12)
AUDIT_MODEL=mistralai/mistral-small-2603

# Force dry-run mode even if API key is present (1/true/yes to enable)
AUDIT_DRY_RUN=

# Directory where output files are saved
AUDIT_OUTPUT_DIR=outputs

# Filename for the compact reliability score CSV
AUDIT_OUTPUT_CSV=reliability_score.csv

# Generate HTML report with charts automatically (1/true/yes to enable)
AUDIT_HTML=

# Append each audit to history file for trend tracking (1/true/yes to enable)
AUDIT_HISTORY=

# Path to the JSONL audit history file
AUDIT_HISTORY_FILE=outputs/audit_history.jsonl

# Score-drop threshold (points) that triggers a regression warning
AUDIT_REGRESSION_THRESHOLD=5.0

# ── Demo Settings ─────────────────────────────────────────────────────────────
# Random seed for reproducible demo runs (integer)
DEMO_SEED=42
